# Variables del docker-compose (EasyPanel: pégalas en Environment del proyecto)

# --- Base de datos ---
POSTGRES_DB=gestorlegal
POSTGRES_USER=gestorlegal
POSTGRES_PASSWORD=cambia_por_una_contraseña_fuerte

# --- App (NextAuth) ---
# El dominio público que asignes en EasyPanel
NEXTAUTH_URL=https://gestorlegal.tudominio.com
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET=genera_un_secreto_largo

# --- API para n8n ---
# Clave que los workflows enviarán en el header x-api-key
N8N_API_KEY=genera_una_clave_larga_y_secreta

# --- Admin inicial ---
# El seed crea este usuario admin en el primer arranque (mínimo 8 caracteres).
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=cambia_por_una_contraseña_fuerte
ADMIN_NOMBRE=Christian
